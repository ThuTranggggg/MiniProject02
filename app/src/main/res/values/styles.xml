<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.ShoppingApp.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/radius_20</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardUseCompatPadding">true</item>
    </style>

    <style name="Widget.ShoppingApp.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_16</item>
    </style>

    <style name="Widget.ShoppingApp.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_16</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <style name="Widget.ShoppingApp.Button.Small" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_12</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.ShoppingApp.InputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_16</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_16</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_16</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_16</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.ShoppingApp.ScreenTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.ShoppingApp.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.ShoppingApp.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
