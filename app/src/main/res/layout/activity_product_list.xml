<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingStart="@dimen/space_20"
    android:paddingTop="@dimen/space_24"
    android:paddingEnd="@dimen/space_20"
    android:paddingBottom="@dimen/space_20">

    <ImageButton
        android:id="@+id/btnBackProductList"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_toolbar_icon"
        android:contentDescription="@string/back"
        android:padding="8dp"
        android:src="@android:drawable/ic_media_previous" />

    <TextView
        android:id="@+id/tvProductListTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_14"
        android:text="@string/products_title"
        android:textAppearance="@style/TextAppearance.ShoppingApp.ScreenTitle" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.ShoppingApp.InputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_18"
        android:hint="@string/hint_search_product"
        app:startIconDrawable="@android:drawable/ic_menu_search">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearchProduct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvProductEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_18"
        android:gravity="center"
        android:text="@string/empty_products"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_16"
        android:layout_weight="1" />

</LinearLayout>
