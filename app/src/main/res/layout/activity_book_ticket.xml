<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_16">

        <ImageButton
            android:id="@+id/btnBackBookTicket"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_toolbar_icon"
            android:contentDescription="@string/back"
            android:padding="8dp"
            android:src="@android:drawable/ic_media_previous" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_14"
            android:text="@string/book_ticket_title"
            android:textAppearance="@style/TextAppearance.ShoppingApp.ScreenTitle" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.ShoppingApp.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_20">

                <ImageView
                    android:id="@+id/ivBookPoster"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@drawable/bg_search_surface"
                    android:contentDescription="@string/product_name_placeholder"
                    android:padding="@dimen/space_20"
                    android:scaleType="fitCenter"
                    android:src="@drawable/product_laptop" />

                <TextView
                    android:id="@+id/tvBookMovieTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:text="@string/product_name_placeholder"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBookMovieMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/price_placeholder"
                    android:textColor="@color/price"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBookTheaterInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/category_placeholder"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvBookShowtimeInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/book_showtime_placeholder"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvBookSeatInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="@string/book_available_seats_placeholder"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:text="@string/book_available_seat_list_title"
                    android:textAppearance="@style/TextAppearance.ShoppingApp.SectionTitle" />

                <TextView
                    android:id="@+id/tvSeatSelectionHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/book_loading_seats"
                    android:textColor="@color/text_secondary" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSeatNumber"
                    style="@style/Widget.ShoppingApp.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:hint="@string/seat_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSeatNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters"
                        android:maxLines="1"
                        android:text="@null"
                        android:hint="@string/hint_seat_number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupAvailableSeats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    app:chipSpacingHorizontal="@dimen/space_8"
                    app:chipSpacingVertical="@dimen/space_8"
                    app:singleLine="false"
                    app:singleSelection="true" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmBooking"
                    style="@style/Widget.ShoppingApp.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_20"
                    android:text="@string/action_book_ticket" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
