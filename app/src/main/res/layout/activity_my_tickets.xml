<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingStart="@dimen/space_20"
    android:paddingTop="@dimen/space_24"
    android:paddingEnd="@dimen/space_20"
    android:paddingBottom="@dimen/space_20">

    <ImageButton
        android:id="@+id/btnBackMyTickets"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_toolbar_icon"
        android:contentDescription="@string/back"
        android:padding="8dp"
        android:src="@android:drawable/ic_media_previous" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_14"
        android:text="@string/ticket_list_title"
        android:textAppearance="@style/TextAppearance.ShoppingApp.ScreenTitle" />

    <TextView
        android:id="@+id/tvTicketHeaderSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:text="@string/ticket_list_login_hint"
        android:textColor="@color/text_secondary" />

    <LinearLayout
        android:id="@+id/layoutTicketLoginRequired"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_18"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/login_required_ticket_list"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTicketLogin"
            style="@style/Widget.ShoppingApp.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:text="@string/action_login" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutTicketEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_24"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/ticket_empty_title"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:gravity="center"
            android:text="@string/ticket_empty_message"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBrowseShowtimes"
            style="@style/Widget.ShoppingApp.Button.Secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:text="@string/showtimes_title" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMyTickets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_16"
        android:layout_weight="1" />

</LinearLayout>
