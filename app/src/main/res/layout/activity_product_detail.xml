<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_16">

        <ImageButton
            android:id="@+id/btnBackProductDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_toolbar_icon"
            android:contentDescription="@string/back"
            android:padding="8dp"
            android:src="@android:drawable/ic_media_previous" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.ShoppingApp.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_20">

                <ImageView
                    android:id="@+id/ivDetailProduct"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@drawable/bg_search_surface"
                    android:contentDescription="@string/product_name_placeholder"
                    android:padding="@dimen/space_20"
                    android:scaleType="fitCenter"
                    android:src="@drawable/product_laptop" />

                <TextView
                    android:id="@+id/tvDetailName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:text="@string/product_name_placeholder"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetailPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/price_placeholder"
                    android:textColor="@color/price"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetailCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/category_placeholder"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvDetailStock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/stock_placeholder"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:text="@string/description_placeholder"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDetailAddToCart"
                    style="@style/Widget.ShoppingApp.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_20"
                    android:text="@string/add_to_invoice" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
